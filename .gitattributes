# Auto detect text files and normalize line endings to LF
* text=auto

# Java sources
*.java text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.properties text eol=lf
*.gradle text eol=lf
*.cfg text eol=lf

# Shell scripts must use LF
*.sh text eol=lf

# Binary files
*.jar binary
*.class binary
*.der binary
*.png binary
*.jpg binary
*.gif binary
